{
	"name": "atlas",
	"description": "Activity tracking and time mapping application",
	"author": "You",
	"private": true,
	"version": "0.0.0",
	"type": "module",
	"main": "electron/main.cjs",
	"scripts": {
		"dev": "concurrently -k \"npm:dev:renderer\" \"npm:dev:electron\"",
		"dev:renderer": "vite",
		"dev:electron": "wait-on tcp:5173 && electron .",
		"start": "electron .",
		"build": "tsc -b && vite build",
		"dist": "npm run build && electron-builder --win --publish never",
		"dist:ci:win": "npm run build && electron-builder --win --publish always",
		"dist:ci:mac": "npm run build && electron-builder --mac --publish always",
		"dist:portable": "npm run build && electron-builder --win portable --publish never",
		"lint": "eslint .",
		"preview": "vite preview"
	},
	"build": {
		"appId": "com.atlas.app",
		"productName": "Atlas",
		"directories": {
			"buildResources": "public",
			"output": "release"
		},
		"files": [
			"dist/**/*",
			"electron/**/*",
			"node_modules/**/*",
			"package.json"
		],
		"publish": [
			{
				"provider": "github",
				"owner": "ntnthefirst",
				"repo": "Atlas"
			}
		],
		"win": {
			"artifactName": "Atlas-Setup-Windows-${arch}.${ext}",
			"icon": "public/icon.ico",
			"target": [
				{
					"target": "nsis",
					"arch": [
						"x64"
					]
				}
			]
		},
		"mac": {
			"artifactName": "Atlas-Setup-macOS-${arch}.${ext}",
			"target": [
				"dmg",
				"zip"
			]
		},
		"nsis": {
			"oneClick": false,
			"allowToChangeInstallationDirectory": true,
			"createDesktopShortcut": true,
			"createStartMenuShortcut": true,
			"shortcutName": "Atlas"
		}
	},
	"dependencies": {
		"@heroicons/react": "^2.2.0",
		"electron-updater": "^6.8.3",
		"framer-motion": "^12.38.0",
		"react": "^19.2.4",
		"react-dom": "^19.2.4",
		"sql.js": "^1.14.1"
	},
	"devDependencies": {
		"@eslint/js": "^9.39.4",
		"@tailwindcss/vite": "^4.2.2",
		"@types/node": "^24.12.0",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"@vitejs/plugin-react": "^6.0.1",
		"concurrently": "^9.2.1",
		"electron": "^41.0.3",
		"electron-builder": "^26.8.1",
		"electronmon": "^2.0.4",
		"eslint": "^9.39.4",
		"eslint-plugin-react-hooks": "^7.0.1",
		"eslint-plugin-react-refresh": "^0.5.2",
		"globals": "^17.4.0",
		"tailwindcss": "^4.2.2",
		"typescript": "~5.9.3",
		"typescript-eslint": "^8.57.0",
		"vite": "^8.0.1",
		"wait-on": "^9.0.4"
	}
}
